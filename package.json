{
  "name": "indonesian-paper-corrector",
  "version": "1.0.0",
  "description": "A Micro-SaaS web application that corrects Indonesian scientific papers using the MiniMax-M3.0-highspeed model via the MiniMax API.",
  "main": "server/server.js",
  "scripts": {
    "postinstall": "npm install --prefix server",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "node server/server.js",
    "server": "cd server && nodemon server.js",
    "client": "npm install --prefix client && npm start --prefix client",
    "prebuild": "npm install --prefix client",
    "build": "npm run build --prefix client"
  },
  "keywords": [
    "indonesian",
    "scientific-paper",
    "correction",
    "minimax"
  ],
  "author": "Developer",
  "license": "MIT",
  "dependencies": {
    "concurrently": "^8.2.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}