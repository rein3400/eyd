# Google OAuth Configuration
# Get your Client ID from Google Cloud Console
# https://console.cloud.google.com/apis/credentials
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com

# API Configuration
# REACT_APP_API_URL is the API origin only — do NOT add `/api` or a trailing
# slash. The source code in src/App.js appends `/api/...` for each endpoint,
# so the final URL is `${REACT_APP_API_URL}/api/upload`, etc.
#   - Local dev: leave blank. The CRA dev proxy in client/package.json
#     routes the resulting relative `/api/*` calls to http://localhost:5000.
#   - Production: set to the Render origin in the Cloudflare Pages env vars,
#     e.g. `https://eyd-jasa.onrender.com`.
REACT_APP_API_URL=http://localhost:5000